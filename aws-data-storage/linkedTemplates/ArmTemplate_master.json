{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "aws-data-storage"
		},
		"StorageRawDataLake_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'StorageRawDataLake'"
		},
		"storageRawdata_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'storageRawdata'"
		},
		"StorageRawDataLake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://awsstoragedata.dfs.core.windows.net/"
		},
		"httpGitTorawService_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "aws-data-storage_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"StorageRawDataLake_accountKey": {
						"value": "[parameters('StorageRawDataLake_accountKey')]"
					},
					"storageRawdata_connectionString": {
						"value": "[parameters('storageRawdata_connectionString')]"
					},
					"StorageRawDataLake_properties_typeProperties_url": {
						"value": "[parameters('StorageRawDataLake_properties_typeProperties_url')]"
					},
					"httpGitTorawService_properties_typeProperties_url": {
						"value": "[parameters('httpGitTorawService_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}